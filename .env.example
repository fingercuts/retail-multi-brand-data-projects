# OmniRetail Analytics: Environment Configuration Template
# Copy this file to .env and fill in the values for your local environment.

# --- PostgreSQL Serving Layer (Docker/RDS) ---
POSTGRES_USER=retail_user
POSTGRES_PASSWORD=retail_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=retail_serving

# --- DuckDB / File Paths ---
DUCKDB_PATH=data/multibrand_retail.duckdb
RAW_DATA_PATH=data/raw/
STAGING_DATA_PATH=data/staging/

# --- API Settings ---
API_LOG_LEVEL=info
DEBUG_MODE=False
